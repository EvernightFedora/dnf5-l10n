#: reposync.cpp:65
msgid "Synchronize a remote DNF repository to a local directory."
msgstr "リモートのDNFリポジトリをローカルディレクトリに同期する。"

#: reposync.cpp:159
msgid "Can't use --norepopath with multiple repositories enabled"
msgstr "複数のリポジトリが有効な状態で --norepopath は使用できません"

#: reposync.cpp:164
msgid "Can't use --safe-write-path with multiple repositories enabled"
msgstr ""
"複数のリポジトリが有効になっている場合、--safe-write-path を使用できません"

#: reposync.cpp:250
#, c++-format
msgid ""
"Download destination '{0}' for location '{1}' of '{2}' package from '{3}' "
"repo is outside of safe write path '{4}'."
msgstr ""
"パッケージ '{2}' の '{1}' の場所のダウンロード先 '{0}' が '{3}' リポジトリ"
"から安全な書き込みパス '{4}' の外にあります。"

#: reposync.cpp:289
#, c++-format
msgid "Failed to create directory '{0}' iterator: {1}"
msgstr "'{0}' ディレクトリのイテレーターの作成に失敗しました: {1}"

#: reposync.cpp:302
#, c++-format
msgid "Failed to delete file {0}: {1}"
msgstr "ファイル {0} の削除に失敗しました: {1}"

#: reposync.cpp:305
#, c++-format
msgid "[DELETED] {}"
msgstr "[DELETED] {}"

#: reposync.cpp:321
#, c++-format
msgid "Removing '{}' with failing OpenPGP check: {}"
msgstr "失敗した OpenPGP チェックで '{}' を削除しています: {}"

#: reposync.cpp:384
msgid "Failed to get mirror for metadata."
msgstr "メタデータのミラーを取得できませんでした。"

#: reposync.cpp:394
#, c++-format
msgid "Failed to get mirror for package: \"{}\""
msgstr "パッケージ {} のミラーを取得できませんでした"

#: reposync.cpp:410
msgid "OpenPGP signature check failed"
msgstr "OpenPGP の署名確認に失敗しました"
